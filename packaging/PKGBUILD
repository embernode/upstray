pkgname=upstray
pkgver=0.2.2
pkgrel=1
pkgdesc="Modern KDE system tray monitor for Network UPS Tools (NUT)"
arch=('x86_64')
url="https://github.com/embernode/upstray"
license=('GPL-3.0-or-later')
depends=('qt6-base' 'qt6-declarative' 'qt6-wayland')
optdepends=('nut: run a local NUT server/driver stack')
conflicts=('upstray-git')
makedepends=('rust' 'cargo' 'cmake')
source=()
sha256sums=()

prepare() {
    # Clean up old builds and copy current source tree, excluding packaging dir
    rm -rf "$srcdir/upstray"
    mkdir -p "$srcdir/upstray"
    cp -a "$startdir/../src" "$startdir/../cpp" "$startdir/../qml" "$startdir/../resources" "$startdir/../build.rs" "$startdir/../Cargo.toml" "$startdir/../Cargo.lock" "$startdir/../LICENSE" "$srcdir/upstray/"
}

build() {
    cd "$srcdir/upstray"
    cargo build --release --locked
}

package() {
    cd "$srcdir/upstray"
    install -Dm755 "target/release/upstray" "$pkgdir/usr/bin/upstray"
    install -Dm644 "resources/upstray.desktop" "$pkgdir/usr/share/applications/upstray.desktop"
    install -Dm644 "resources/icons/upstray.svg" "$pkgdir/usr/share/icons/hicolor/scalable/apps/upstray.svg"
    install -Dm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
